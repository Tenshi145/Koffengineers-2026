venv/
env/
.venv/
ENV/
env.bak/
venv.bak/
.virtualenv/

# Flask / Django
instance/
.webassets-cache
*.db
*.sqlite3

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# Mypy / Type checkers
.mypy_cache/
.dmypy.json
dmypy.json

# ─── Node / Frontend ────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Build output
client/dist/
client/build/
.next/
.nuxt/

# Vite
.vite/

# ─── Variables de entorno (NUNCA al repo) ───────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
*.env

# ─── IDEs y Editores ────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# JetBrains
*.iml
*.ipr
*.iws
.idea/

# ─── Sistema Operativo ──────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux / Raspberry Pi
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*
core
*.pid

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
log/
npm-debug.log
pip-log.txt

# ─── Base de datos ──────────────────────────────────────────
*.sql.bak
*.dump
backups/

# ─── Archivos temporales ────────────────────────────────────
tmp/
temp/
*.tmp
*.temp
*.bak
*.orig
*.rej

